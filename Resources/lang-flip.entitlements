<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Hardened-runtime entitlements for Developer ID-signed lang-flip.
      The app is intentionally NOT sandboxed — it has to read keystrokes
      across all apps via CGEventTap, which the sandbox prohibits.
      Distribution path is "outside the Mac App Store", which is fine
      with hardened runtime + notarization.

      Microphone access is optional and used only for the future dictation
      feature. Hardened runtime requires this entitlement before macOS will
      show the microphone consent prompt.

      We do NOT need any of the security.cs.* opt-outs (allow-jit,
      allow-unsigned-executable-memory, etc.) — the binary is plain Swift
      with no JIT or runtime code generation.
    -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
