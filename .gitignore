# Apple signing / notarization material. These must live in Keychain,
# developer machines, or CI secret storage, never in git.
*.p8
*.p12
*.pem
*.cer
*.certSigningRequest
*.mobileprovision
*.provisionprofile
*.xcarchive
*.dSYM/

